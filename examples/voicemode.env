# VoiceMode example configuration for routing all STT/TTS through voicemux.
# Start voicemux first, then point VoiceMode at the local OpenAI-compatible edge.

VOICEMODE_STT_BASE_URLS=http://127.0.0.1:8787/v1
VOICEMODE_TTS_BASE_URLS=http://127.0.0.1:8787/v1

# Use a provider-neutral voice alias from voicemux.yaml.
VOICEMODE_VOICES=assistant
